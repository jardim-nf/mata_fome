rgueres', 'baguetes', 'pizzas', 'porcoes'],\r\n        'porcoes': ['bebidas', 'refrigerante', 'sucos'],\r\n    };\r\n    const catsSugeridas = new Set();\r\n    categoriasNoCarrinho.forEach(cat => {\r\n        Object.entries(sugestaoMap).forEach(([key, vals]) => { if (cat.includes(key)) vals.forEach(v => catsSugeridas.add(v)); });\r\n    });\r\n    if (catsSugeridas.size === 0) { catsSugeridas.add('bebidas'); catsSugeridas.add('sobremesas'); }\r\n    const sugestoes = allProdutos.filter(p => !idsNoCarrinho.has(p.id) && p.ativo !== false && [...catsSugeridas].some(s => (p.categoria || '').toLowerCase().includes(s))).slice(0, 4);\r\n    \r\n    if (sugestoes.length === 0) return null;\r\n    return (\r\n        <div className=\"mb-8 bg-gradient-to-r from-amber-50 to-orange-50 rounded-2xl p-4 border border-amber-100\">\r\n            <h3 className=\"text-base font-black text-gray-800 mb-3 flex items-center gap-2\">­ƒÆí Vai bem com o que voc├¬ pediu</h3>\r\n            <div className=\"grid grid-cols-2 gap-2\">\r\n                {sugestoes.map((item, index) => (\r\n                    <button key={`sugestao-${item.id}-${index}`} onClick={() => handleAbrirModalProduto(item)} className=\"bg-white rounded-xl p-3 border border-amber-100 flex items-center gap-3 hover:shadow-md hover:border-amber-200 transition-all text-left active:scale-[0.98]\">\r\n                        <div className=\"w-12 h-12 rounded-lg bg-gray-100 overflow-hidden shrink-0\">{item.imageUrl && <img src={item.imageUrl} alt=\"\" className=\"w-full h-full object-cover\" />}</div>\r\n                        <div className=\"flex-1 min-w-0\">\r\n                            <p className=\"text-xs font-bold text-gray-800 truncate\">{item.nome}</p>\r\n                            <p className=\"text-[10px] font-bold text-emerald-600\">R$ {(Number(item.preco) || 0).toLocaleString('pt-BR', { minimumFractionDigits: 2 })}</p>\r\n                        </div>\r\n                    </button>\r\n                ))}\r\n            </div>\r\n        </div>\r\n    );\r\n}","usedDeprecatedRules":[{"ruleId":"no-extra-semi","replacedBy":["@stylistic/no-extra-semi"],"info":{"message":"Formatting rules are being moved out of ESLint core.","url":"https://eslint.org/blog/2023/10/deprecating-formatting-rules/","deprecatedSince":"8.53.0","availableUntil":"11.0.0","replacedBy":[{"message":"ESLint Stylistic now maintains deprecated stylistic core rules.","url":"https://eslint.style/guide/migration","plugin":{"name":"@stylistic/eslint-plugin","url":"https://eslint.style"},"rule":{"name":"no-extra-semi","url":"https://eslint.style/rules/no-extra-semi"}}]}},{"ruleId":"no-mixed-spaces-and-tabs","replacedBy":["@stylistic/no-mixed-spaces-and-tabs"],"info":{"message":"Formatting rules are being moved out of ESLint core.","url":"https://eslint.org/blog/2023/10/deprecating-formatting-rules/","deprecatedSince":"8.53.0","availableUntil":"11.0.0","replacedBy":[{"message":"ESLint Stylistic now maintains deprecated stylistic core rules.","url":"https://eslint.style/guide/migration","plugin":{"name":"@stylistic/eslint-plugin","url":"https://eslint.style"},"rule":{"name":"no-mixed-spaces-and-tabs","url":"https://eslint.style/rules/no-mixed-spaces-and-tabs"}}]}},{"ruleId":"no-new-symbol","replacedBy":["no-new-native-nonconstructor"],"info":{"message":"The rule was replaced with a more general rule.","url":"https://eslint.org/docs/latest/use/migrate-to-9.0.0#eslint-recommended","deprecatedSince":"9.0.0","availableUntil":"11.0.0","replacedBy":[{"rule":{"name":"no-new-native-nonconstructor","url":"https://eslint.org/docs/latest/rules/no-new-native-nonconstructor"}}]}}]},{"filePath":"C:\\Users\\Matheus\\Documents\\matafome-landing-atualizado\\matafome-landing-atualizado\\src\\pages\\NossosClientes.jsx","messages":[{"ruleId":"react-refresh/only-export-components","severity":1,"message":"Fast refresh only works when a file only exports components. Move your component(s) to a separate file.","line":17,"column":10,"nodeType":"Identifier","messageId":"localComponents","endLine":17,"endColumn":26},{"ruleId":"react-refresh/only-export-components","severity":1,"message":"Fast refresh can't handle anonymous components. Add a name to your export.","line":374,"column":16,"nodeType":"CallExpression","messageId":"anonymousExport","endLine":374,"endColumn":55}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":2,"fixableErrorCount":0,"fixableWarningCount":0,"source":"// src/pages/ClientManagement.jsx\r\nimport React, { useState, useEffect, useCallback } from 'react';\r\nimport { useAuth } from '../context/AuthContext';\r\nimport { useNavigate } from 'react-router-dom';\r\nimport { httpsCallable } from 'firebase/functions';\r\nimport { functions, db } from '../firebase';\r\nimport { doc, getDoc, collection, getDocs, query, where, orderBy, limit } from 'firebase/firestore';\r\nimport withEstablishmentAuth from '../hocs/withEstablishmentAuth';\r\nimport { FaArrowLeft, FaWhatsapp, FaEnvelopeOpenText, FaUsers, FaCheckCircle } from 'react-icons/fa';\r\nimport { toast } from 'react-toastify';\r\nimport BackButton from '../components/BackButton';\r\n\r\n/**\r\n * Componente para o administrador de um estabelecimento enviar mensagens em massa\r\n * APENAS para os clientes que j├í fizeram pedidos nesse estabelecimento.\r\n */\r\nfunction ClientManagement({ estabelecimentoPrincipal }) {\r\n    const { currentUser, userData } = useAuth();\r\n    const navigate = useNavigate();\r\n\r\n    // Pega o ID do estabelecimento que o usu├írio est├í gerenciando\r\n    const estabelecimentoId = estabelecimentoPrincipal;\r\n    const [estabelecimentoNome, setEstabelecimentoNome] = useState('Carregando...');\r\n\r\n    const [message, setMessage] = useState('');\r\n    const [isSending, setIsSending] = useState(false);\r\n    const [sendResult, setSendResult] = useState(null);\r\n    const [clientCount, setClientCount] = useState(null); \r\n    const [loadingCount, setLoadingCount] = useState(true);\r\n    const [messageHistory, setMessageHistory] = useState([]);\r\n    const [loadingHistory, setLoadingHistory] = useState(false);\r\n\r\n    // Busca o nome real do estabelecimento no Firestore\r\n    useEffect(() => {\r\n        const fetchNomeEstabelecimento = async () => {\r\n            if (estabelecimentoId) {\r\n                try {\r\n                    const docRef = doc(db, \"estabelecimentos\", estabelecimentoId);\r\n                    const docSnap = await getDoc(docRef);\r\n                    if (docSnap.exists()) {\r\n                        setEstabelecimentoNome(docSnap.data().nome || 'Seu Estabelecimento');\r\n                    } else {\r\n                        setEstabelecimentoNome('Seu Estabelecimento');\r\n                    }\r\n                } catch (error) {\r\n                    console.error(\"Erro ao buscar nome do estabelecimento:\", error);\r\n                    setEstabelecimentoNome('Seu Estabelecimento');\r\n                }\r\n            }\r\n        };\r\n        fetchNomeEstabelecimento();\r\n    }, [estabelecimentoId]);\r\n\r\n    // FUN├ç├âO: BUSCA A CONTAGEM REAL NO BACKEND\r\n    const fetchClientCount = useCallback(async () => {\r\n        if (!estabelecimentoId) return;\r\n\r\n        setLoadingCount(true);\r\n        try {\r\n            const pedidosRef = collection(db, 'estabelecimentos', estabelecimentoId, 'pedidos');\r\n            const snap = await getDocs(pedidosRef);\r\n            \r\n            // Usamos um Set para guardar telefones ├║nicos\r\n            const uniquePhones = new Set();\r\n            \r\n            snap.forEach(docSnap => {\r\n                const data = docSnap.data();\r\n                const phone = data?.cliente?.telefone;\r\n                if (phone && phone.trim() !== '') {\r\n                    // Normaliza o telefone removendo caracteres n├úo num├®ricos\r\n                    const cleanPhone = phone.replace(/\\D/g, '');\r\n                    if (cleanPhone.length >= 10) {\r\n                        uniquePhones.add(cleanPhone);\r\n                    }\r\n                }\r\n            });\r\n            \r\n            setClientCount(uniquePhones.size);\r\n        } catch (error) {\r\n            console.error(\"Erro ao buscar contagem de clientes:\", error);\r\n            toast.error(\"Erro ao carregar o n├║mero de clientes.\");\r\n            setClientCount(0); \r\n        } finally {\r\n            setLoadingCount(false);\r\n        }\r\n    }, [estabelecimentoId]);\r\n\r\n    // FUN├ç├âO: CARREGAR HIST├ôRICO DE MENSAGENS\r\n    const fetchMessageHistory = useCallback(async () => {\r\n        if (!estabelecimentoId) return;\r\n\r\n        setLoadingHistory(true);\r\n        try {\r\n            const campSnap = await getDocs(\r\n                query(\r\n                    collection(db, 'estabelecimentos', estabelecimentoId, 'campanhas'),\r\n                    where('tipo', '==', 'envio_massa'),\r\n                    orderBy('enviadoEm', 'desc'),\r\n                    limit(50)\r\n                )\r\n            );\r\n            setMessageHistory(campSnap.docs.map(d => ({ id: d.id, ...d.data() })));\r\n        } catch (error) {\r\n            console.error(\"Erro ao carregar hist├│rico:\", error);\r\n            setMessageHistory([]);\r\n        } finally {\r\n            setLoadingHistory(false);\r\n        }\r\n    }, [estabelecimentoId]);\r\n\r\n    // useEffect para buscar dados na montagem\r\n    useEffect(() => {\r\n        if (estabelecimentoId) {\r\n            fetchClientCount();\r\n            fetchMessageHistory();\r\n        }\r\n    }, [estabelecimentoId, fetchClientCount, fetchMessageHistory]);\r\n\r\n    // Fun├º├úo para disparar o envio em massa para a Cloud Function\r\n    const handleSendEstablishmentMessage = useCallback(async () => {\r\n        if (isSending || !message.trim()) {\r\n            toast.warn('A mensagem n├úo pode ser vazia.');\r\n            return;\r\n        }\r\n\r\n        if (clientCount === 0) {\r\n            toast.info('N├úo h├í clientes com hist├│rico de pedidos para enviar a mensagem.');\r\n            return;\r\n        }\r\n\r\n        if (!window.confirm(`Tem certeza que deseja enviar esta mensagem via WhatsApp para ${clientCount} clientes que j├í fizeram pedidos em ${estabelecimentoNome}?`)) {\r\n            return;\r\n        }\r\n\r\n        setIsSending(true);\r\n        setSendResult(null);\r\n\r\n        try {\r\n            // Chama a Cloud Function de envio REAL\r\n            const sendFunction = httpsCallable(functions, 'sendEstablishmentMessageCallable');\r\n            \r\n            const result = await sendFunction({ \r\n                estabelecimentoId, \r\n                message: message.trim() \r\n            });\r\n\r\n            setSendResult({ \r\n                status: 'success', \r\n                details: result.data.message,\r\n                data: result.data\r\n            });\r\n            \r\n            toast.success(`Ô£à ${result.data.message}`);\r\n            \r\n            // Atualiza a contagem ap├│s o envio\r\n            fetchClientCount();\r\n            fetchMessageHistory();\r\n\r\n        } catch (err) {\r\n            console.error(\"Erro ao enviar mensagem do estabelecimento:\", err);\r\n            setSendResult({ \r\n                status: 'error', \r\n                details: `Falha: ${err.message}`\r\n            });\r\n            toast.error(`ÔØî Erro: ${err.message}`);\r\n\r\n        } finally {\r\n            setIsSending(false);\r\n            // N├úo limpa a mensagem automaticamente para permitir reenvio\r\n        }\r\n    }, [isSending, message, estabelecimentoId, estabelecimentoNome, clientCount, fetchClientCount, fetchMessageHistory]);\r\n\r\n    // Template de mensagens pr├®-definidas\r\n    const messageTemplates = [\r\n        {\r\n            title: \"­ƒöÑ Promo├º├úo Rel├ómpago\",\r\n            message: `­ƒöÑ *PROMO├ç├âO REL├éMPAGO* ­ƒöÑ\\n\\nOi! Aqui ├® o *${estabelecimentoNome}*! ­ƒÿï\\n\\nS├│ HOJE: *20% OFF* em todo o card├ípio! ­ƒÄë\\n\\n├ë por tempo limitado, n├úo perca! Pe├ºa agora pelo nosso delivery ­ƒæç\\n\\n­ƒô▓ Fa├ºa seu pedido e mate essa fome com desconto!`\r\n        },\r\n        {\r\n            title: \"­ƒìö Novidade no Card├ípio\",\r\n            message: `­ƒìö *NOVIDADE QUENTINHA!* ­ƒìö\\n\\nE a├¡, tudo bem? Aqui ├® o *${estabelecimentoNome}*!\\n\\nTemos novidades incr├¡veis no card├ípio que voc├¬ precisa experimentar! ­ƒññ\\n\\nVem conferir e nos conta o que achou! Pe├ºa pelo delivery ­ƒøÁ­ƒÆ¿`\r\n        },\r\n        {\r\n            title: \"­ƒÄü Cupom de Fidelidade\",\r\n            message: `­ƒÄü *PRESENTE PRA VOC├è!*\\n\\nOi! Voc├¬ ├® cliente especial do *${estabelecimentoNome}* e queremos te agradecer! ÔØñ´©Å\\n\\nUse o cupom *FIDEL10* e ganhe *10% OFF* no pr├│ximo pedido!\\n\\nÔÅ░ V├ílido por 7 dias\\n\\n­ƒô▓ Pe├ºa agora e aproveite!`\r\n        },\r\n        {\r\n            title: \"­ƒÜÜ Frete Gr├ítis\",\r\n            message: `­ƒÜÜ *FRETE GR├üTIS!* ­ƒÄë\\n\\nOi! O *${estabelecimentoNome}* t├í com *entrega GR├üTIS* hoje!\\n\\nAproveita pra pedir aquele prato que voc├¬ ama sem pagar nada de taxa! ­ƒÿì\\n\\n­ƒô▓ Corre que ├® s├│ hoje!`\r\n        },\r\n        {\r\n            title: \"Ô¡É Pe├ºa sua Avalia├º├úo\",\r\n            message: `Oi! Aqui ├® o *${estabelecimentoNome}*! ­ƒÿè\\n\\nVoc├¬ pediu com a gente recentemente e queremos saber: *gostou?*\\n\\nÔ¡É Sua opini├úo ├® super importante pra gente melhorar cada vez mais!\\n\\nNos conte o que achou, estamos ouvindo! ­ƒÖÅ`\r\n        },\r\n        {\r\n            title: \"­ƒì¢´©Å Combo Especial\",\r\n            message: `­ƒì¢´©Å *COMBO IMPERD├ìVEL!* ­ƒì¢´©Å\\n\\nOi! O *${estabelecimentoNome}* preparou um combo especial pra voc├¬!\\n\\nÔ£à Prato + Bebida + Sobremesa com pre├ºo ├║nico!\\n\\n­ƒÿï S├│ pedir e aproveitar! V├ílido enquanto durar o estoque.\\n\\n­ƒô▓ Pe├ºa agora pelo delivery!`\r\n        },\r\n        {\r\n            title: \"­ƒôà Hor├írio Especial / Feriado\",\r\n            message: `­ƒôó *AVISO IMPORTANTE*\\n\\nOi! Aqui ├® o *${estabelecimentoNome}*!\\n\\nInformamos que nosso hor├írio ser├í diferenciado:\\n\\n­ƒôà Funcionamento especial neste feriado\\n­ƒòÉ Das 11h ├ás 22h\\n\\nPrograme seu pedido! ­ƒÿë\\nEstamos te esperando! ­ƒøÁ`\r\n        },\r\n        {\r\n            title: \"ÔØñ´©Å Agradecimento\",\r\n            message: `ÔØñ´©Å *MUITO OBRIGADO!*\\n\\nOi! Aqui ├® o *${estabelecimentoNome}*!\\n\\nPassando pra agradecer por ser nosso cliente! Cada pedido seu faz a diferen├ºa pra gente. ­ƒÖÅ\\n\\nConte sempre com a gente quando bater aquela fome! ­ƒÿï­ƒøÁ\\n\\nAbra├ºo da equipe *${estabelecimentoNome}*! ­ƒÆÜ`\r\n        }\r\n    ];\r\n\r\n    // Exibi├º├úo de carregamento\r\n    const displayClientCount = loadingCount ? (\r\n        <span className=\"text-gray-400\">\r\n            <svg className=\"animate-spin inline-block mr-2 h-4 w-4 text-gray-400\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\">\r\n                <circle className=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" strokeWidth=\"4\"></circle>\r\n                <path className=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\"></path>\r\n            </svg>\r\n            Contando clientes...\r\n        </span>\r\n    ) : (\r\n        <strong className=\"text-red-600\">{clientCount}</strong>\r\n    );\r\n\r\n    return (\r\n        <div className=\"min-h-screen bg-gray-50 py-8 text-sm sm:text-base lg:px-8\">\r\n            <div className=\"max-w-4xl mx-auto\">\r\n                {/* Header */}\r\n                <BackButton className=\"mb-6\" onClick={() => navigate('/dashboard')} />\r\n\r\n                <div className=\"text-center mb-8\">\r\n                    <h1 className=\"text-3xl font-bold text-gray-900 mb-2 flex items-center justify-center\">\r\n                        <FaEnvelopeOpenText className=\"mr-3 text-red-600\" />\r\n                        Comunica├º├úo com Clientes\r\n                    </h1>\r\n                    <p className=\"text-lg text-gray-600\">\r\n                        Envie mensagens via WhatsApp para clientes de <strong>{estabelecimentoNome}</strong>\r\n                    </p>\r\n                </div>\r\n\r\n                {/* Estat├¡sticas R├ípidas */}\r\n                <div className=\"grid grid-cols-1 md:grid-cols-3 gap-4 mb-8\">\r\n                    <div className=\"bg-white p-4 rounded-lg shadow border border-gray-200 text-center\">\r\n                        <FaUsers className=\"text-blue-500 text-2xl mx-auto mb-2\" />\r\n                        <div className=\"text-2xl font-bold text-gray-800\">{displayClientCount}</div>\r\n                        <div className=\"text-sm text-gray-600\">Clientes ├Ünicos</div>\r\n                    </div>\r\n                    <div className=\"bg-white p-4 rounded-lg shadow border border-gray-200 text-center\">\r\n                        <FaWhatsapp className=\"text-green-500 text-2xl mx-auto mb-2\" />\r\n                        <div className=\"text-2xl font-bold text-gray-800\">WhatsApp</div>\r\n                        <div className=\"text-sm text-gray-600\">Integra├º├úo Ativa</div>\r\n                    </div>\r\n                    <div className=\"bg-white p-4 rounded-lg shadow border border-gray-200 text-center\">\r\n                        <FaCheckCircle className=\"text-green-500 text-2xl mx-auto mb-2\" />\r\n                        <div className=\"text-2xl font-bold text-gray-800\">Pronto</div>\r\n                        <div className=\"text-sm text-gray-600\">Para Enviar</div>\r\n                    </div>\r\n                </div>\r\n\r\n                <div className=\"grid grid-cols-1 lg:grid-cols-3 gap-8\">\r\n                    {/* Painel Principal de Envio */}\r\n                    <div className=\"lg:col-span-2\">\r\n                        <div className=\"bg-white p-6 sm:p-8 rounded-2xl shadow-xl border border-red-200\">\r\n                            <h2 className=\"text-2xl font-semibold text-gray-800 mb-4 flex items-center\">\r\n                                <FaWhatsapp className=\"mr-2 text-green-500\" />\r\n                                Mensagem via WhatsApp\r\n                            </h2>\r\n\r\n                            <div className=\"mb-6 p-4 bg-blue-50 rounded-lg border border-blue-200\">\r\n                                <p className=\"text-sm text-blue-800\">\r\n                                    <strong>­ƒôè Base de clientes:</strong> {displayClientCount} clientes ├║nicos que j├í fizeram pedidos no seu estabelecimento.\r\n                                </p>\r\n                            </div>\r\n\r\n                            <textarea\r\n                                className=\"w-full p-4 border border-gray-300 rounded-lg focus:ring-2 focus:ring-red-500 focus:border-red-500 mb-4 resize-none transition duration-150\"\r\n                                rows=\"6\"\r\n                                placeholder={`Digite a mensagem que ser├í enviada para todos os clientes via WhatsApp. Ex: \"Prezado cliente, informamos que ${estabelecimentoNome} ter├í hor├írio especial neste feriado...\"`}\r\n                                value={message}\r\n                                onChange={(e) => setMessage(e.target.value)}\r\n                                disabled={isSending || loadingCount}\r\n                            />\r\n                            \r\n                            <div className=\"flex w-full gap-3\">\r\n                                <button\r\n                                    onClick={handleSendEstablishmentMessage}\r\n                                    disabled={isSending || loadingCount || !message.trim() || clientCount === 0}\r\n                                    className={`flex-1 inline-flex justify-center items-center px-6 py-3 border border-transparent text-base font-medium rounded-md shadow-sm text-white ${\r\n                                        isSending || loadingCount || !message.trim() || clientCount === 0\r\n                                            ? 'bg-gray-400 cursor-not-allowed'\r\n                                            : 'bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transform hover:scale-105 transition duration-200'\r\n                                    }`}\r\n                                >\r\n                                    {isSending ? (\r\n                                        <>\r\n                                            <svg className=\"animate-spin -ml-1 mr-3 h-5 w-5 text-white\" xmlns=\"http://www.w3.org/2000/svg\" fill=\"none\" viewBox=\"0 0 24 24\">\r\n                                                <circle className=\"opacity-25\" cx=\"12\" cy=\"12\" r=\"10\" stroke=\"currentColor\" strokeWidth=\"4\"></circle>\r\n                                                <path className=\"opacity-75\" fill=\"currentColor\" d=\"M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z\"></path>\r\n                                            </svg>\r\n                                            Enviando WhatsApp...\r\n                                        </>\r\n                                    ) : (\r\n                                        `­ƒôñ Enviar para ${clientCount !== null ? clientCount : '...'} Clientes`\r\n                                    )}\r\n                                </button>\r\n\r\n                                <button\r\n                                    onClick={() => setMessage('')}\r\n                                    disabled={isSending || !message.trim()}\r\n                                    className=\"px-4 py-3 border border-gray-300 text-gray-700 rounded-md hover:bg-gray-50 transition duration-200\"\r\n                                >\r\n                                    Limpar\r\n                                </button>\r\n                            </div>\r\n\r\n                            {sendResult && (\r\n                                <div className={`mt-4 p-4 rounded-lg border ${\r\n                                    sendResult.status === 'success' \r\n                                        ? 'bg-green-100 text-green-800 border-green-300' \r\n                                        : 'bg-red-100 text-red-800 border-red-300'\r\n                                }`}>\r\n                                    <div className=\"font-semibold\">\r\n                                        {sendResult.status === 'success' ? 'Ô£à Sucesso!' : 'ÔØî Erro'}\r\n                                    </div>\r\n                                    <div className=\"text-sm mt-1\">{sendResult.details}</div>\r\n                                    {sendResult.data && (\r\n                                        <div className=\"text-xs mt-2 p-2 bg-white rounded border\">\r\n                                            <pre>{JSON.stringify(sendResult.data, null, 2)}</pre>\r\n                                        </div>\r\n                                    )}\r\n                                </div>\r\n                            )}\r\n                        </div>\r\n                    </div>\r\n\r\n                    {/* Sidebar - Templates e Informa├º├Áes */}\r\n                    <div className=\"space-y-6\">\r\n                        {/* Templates R├ípidos */}\r\n                        <div className=\"bg-white p-6 rounded-2xl shadow border border-gray-200\">\r\n                            <h3 className=\"text-lg font-semibold text-gray-800 mb-3\">\r\n                                ­ƒÆí Templates Prontos\r\n                            </h3>\r\n                            <div className=\"space-y-2 max-h-[420px] overflow-y-auto pr-1\">\r\n                                {messageTemplates.map((template, index) => (\r\n                                    <button\r\n                                        key={index}\r\n                                        onClick={() => setMessage(template.message)}\r\n                                        disabled={isSending}\r\n                                        className=\"w-full text-left p-3 text-sm bg-gray-50 hover:bg-green-50 rounded-lg border border-gray-200 transition duration-200 hover:border-green-400 hover:shadow-sm\"\r\n                                    >\r\n                                        <div className=\"font-medium text-gray-800\">{template.title}</div>\r\n                                        <div className=\"text-gray-500 text-xs mt-1 truncate\">\r\n                                            {template.message.replace(/\\\\n/g, ' ').replace(/\\*/g, '').substring(0, 55)}...\r\n                                        </div>\r\n                                    </button>\r\n                                ))}\r\n                            </div>\r\n                        </div>\r\n\r\n                        {/* Informa├º├Áes Importantes */}\r\n                        <div className=\"bg-yellow-50 p-4 rounded-lg border border-yellow-200\">\r\n                            <h4 className=\"font-semibold text-yellow-800 mb-2\">ÔÜá´©Å Importante</h4>\r\n                            <ul className=\"text-sm text-yellow-700 space-y-1\">\r\n                                <li>ÔÇó Mensagens s├úo enviadas via WhatsApp</li>\r\n                                <li>ÔÇó Aprox. 1 segundo entre cada envio</li>\r\n                                <li>ÔÇó N├úo spam - apenas comunica├º├Áes importantes</li>\r\n                                <li>ÔÇó Client base: quem j├í fez pedidos conosco</li>\r\n                            </ul>\r\n                        </div>\r\n                    </div>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    );\r\n}\r\n\r\nexport default withEstablishmentAuth(ClientManagement);","usedDeprecatedRules":[{"ruleId":"no-extra-semi","replacedBy":["@stylistic/no-extra-semi"],"info":{"message":"Formatting rules are being moved out of ESLint core.","url":"https://eslint.org/blog/2023/10/deprecating-formatting-rules/","deprecatedSince":"8.53.0","availableUntil":"11.0.0","replacedBy":[{"message":"ESLint Stylistic now maintains deprecated stylistic core rules.","url":"https://eslint.style/guide/migration","plugin":{"name":"@stylistic/eslint-plugin","url":"https://eslint.style"},"rule":{"name":"no-extra-semi","url":"https://eslint.style/rules/no-extra-semi"}}]}},{"ruleId":"no-mixed-spaces-and-tabs","replacedBy":["@stylistic/no-mixed-spaces-and-tabs"],"info":{"message":"Formatting rules are being moved out of ESLint core.","url":"https://eslint.org/blog/2023/10/deprecating-formatting-rules/","deprecatedSince":"8.53.0","availableUntil":"11.0.0","replacedBy":[{"message":"ESLint Stylistic now maintains deprecated stylistic core rules.","url":"https://eslint.style/guide/migration","plugin":{"name":"@stylistic/eslint-plugin","url":"https://eslint.style"},"rule":{"name":"no-mixed-spaces-and-tabs","url":"https://eslint.style/rules/no-mixed-spaces-and-tabs"}}]}},{"ruleId":"no-new-symbol","replacedBy":["no-new-native-nonconstructor"],"info":{"message":"The rule was replaced with a more general rule.","url":"https://eslint.org/docs/latest/use/migrate-to-9.0.0#eslint-recommended","deprecatedSince":"9.0.0","availableUntil":"11.0.0","replacedBy":[{"rule":{"name":"no-new-native-nonconstructor","url":"https://eslint.org/docs/latest/rules/no-new-native-nonconstructor"}}]}}]},{"filePath":"C:\\Users\\Matheus\\Documents\\matafome-landing-atualizado\\matafome-landing-atualizado\\src\\pages\\PaginaImpressao.jsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useMemo has an unnecessary dependency: 'pedido'. Either exclude it or remove the dep