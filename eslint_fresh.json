es/no-new-native-nonconstructor"}}]}}]},{"filePath":"C:\\Users\\Matheus\\Documents\\matafome-landing-atualizado\\matafome-landing-atualizado\\src\\pages\\admin\\RelatorioNfce.jsx","messages":[],"suppressedMessages":[{"ruleId":"react-refresh/only-export-components","severity":1,"message":"Fast refresh only works when a file only exports components. Move your component(s) to a separate file.","line":16,"column":10,"nodeType":"Identifier","messageId":"localComponents","endLine":16,"endColumn":23,"suppressions":[{"kind":"directive","justification":""}]},{"ruleId":"react-refresh/only-export-components","severity":1,"message":"Fast refresh only works when a file only exports components. Move your component(s) to a separate file.","line":380,"column":10,"nodeType":"Identifier","messageId":"localComponents","endLine":380,"endColumn":18,"suppressions":[{"kind":"directive","justification":""}]},{"ruleId":"react-refresh/only-export-components","severity":1,"message":"Fast refresh can't handle anonymous components. Add a name to your export.","line":389,"column":16,"nodeType":"CallExpression","messageId":"anonymousExport","endLine":389,"endColumn":52,"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[{"ruleId":"no-extra-semi","replacedBy":["@stylistic/no-extra-semi"],"info":{"message":"Formatting rules are being moved out of ESLint core.","url":"https://eslint.org/blog/2023/10/deprecating-formatting-rules/","deprecatedSince":"8.53.0","availableUntil":"11.0.0","replacedBy":[{"message":"ESLint Stylistic now maintains deprecated stylistic core rules.","url":"https://eslint.style/guide/migration","plugin":{"name":"@stylistic/eslint-plugin","url":"https://eslint.style"},"rule":{"name":"no-extra-semi","url":"https://eslint.style/rules/no-extra-semi"}}]}},{"ruleId":"no-mixed-spaces-and-tabs","replacedBy":["@stylistic/no-mixed-spaces-and-tabs"],"info":{"message":"Formatting rules are being moved out of ESLint core.","url":"https://eslint.org/blog/2023/10/deprecating-formatting-rules/","deprecatedSince":"8.53.0","availableUntil":"11.0.0","replacedBy":[{"message":"ESLint Stylistic now maintains deprecated stylistic core rules.","url":"https://eslint.style/guide/migration","plugin":{"name":"@stylistic/eslint-plugin","url":"https://eslint.style"},"rule":{"name":"no-mixed-spaces-and-tabs","url":"https://eslint.style/rules/no-mixed-spaces-and-tabs"}}]}},{"ruleId":"no-new-symbol","replacedBy":["no-new-native-nonconstructor"],"info":{"message":"The rule was replaced with a more general rule.","url":"https://eslint.org/docs/latest/use/migrate-to-9.0.0#eslint-recommended","deprecatedSince":"9.0.0","availableUntil":"11.0.0","replacedBy":[{"rule":{"name":"no-new-native-nonconstructor","url":"https://eslint.org/docs/latest/rules/no-new-native-nonconstructor"}}]}}]},{"filePath":"C:\\Users\\Matheus\\Documents\\matafome-landing-atualizado\\matafome-landing-atualizado\\src\\pages\\admin\\ResponderAvaliacoes.jsx","messages":[{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has missing dependencies: 'estabelecimentoIdPrincipal' and 'userData'. Either include them or remove the dependency array.","line":41,"column":6,"nodeType":"ArrayExpression","endLine":41,"endColumn":15,"suggestions":[{"desc":"Update the dependencies array to be: [estabId, estabelecimentoIdPrincipal, userData]","fix":{"range":[2100,2109],"text":"[estabId, estabelecimentoIdPrincipal, userData]"}}]}],"suppressedMessages":[{"ruleId":"react-refresh/only-export-components","severity":1,"message":"Fast refresh only works when a file only exports components. Move your component(s) to a separate file.","line":14,"column":10,"nodeType":"Identifier","messageId":"localComponents","endLine":14,"endColumn":29,"suppressions":[{"kind":"directive","justification":""}]},{"ruleId":"react-refresh/only-export-components","severity":1,"message":"Fast refresh can't handle anonymous components. Add a name to your export.","line":165,"column":16,"nodeType":"CallExpression","messageId":"anonymousExport","endLine":165,"endColumn":58,"suppressions":[{"kind":"directive","justification":""}]}],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"/* eslint-disable react-refresh/only-export-components */\n// src/pages/admin/ResponderAvaliacoes.jsx ÔÇö Admin responde avalia├º├Áes dos clientes\r\nimport React, { useState, useEffect } from 'react';\r\nimport BackButton from '../../components/BackButton';\r\n\r\nimport { collection, getDocs, doc, updateDoc, query, orderBy } from 'firebase/firestore';\r\nimport { db } from '../../firebase';\r\nimport { useAuth } from '../../context/AuthContext';\r\nimport withEstablishmentAuth from '../../hocs/withEstablishmentAuth';\r\nimport { Link } from 'react-router-dom';\r\nimport { toast } from 'react-toastify';\r\nimport { IoArrowBack, IoStarOutline, IoStar, IoChatbubbleEllipsesOutline, IoSendOutline, IoCheckmarkCircle } from 'react-icons/io5';\r\n\r\nfunction ResponderAvaliacoes() {\r\n  const { userData, estabelecimentoIdPrincipal } = useAuth();\r\n  const estabId = estabelecimentoIdPrincipal;\r\n  const [pedidos, setPedidos] = useState([]);\r\n  const [loading, setLoading] = useState(true);\r\n  const [respostas, setRespostas] = useState({});\r\n  const [filtro, setFiltro] = useState('todos'); // todos, sem_resposta, respondidos\r\n\r\n  useEffect(() => {\r\n    if (!estabId) { console.warn('ÔÜá´©Å estabId n├úo encontrado:', { userData, estabelecimentoIdPrincipal }); return; }\r\n    const load = async () => {\r\n      console.log('­ƒôï Carregando avalia├º├Áes para estabId:', estabId);\r\n      const snap = await getDocs(query(collection(db, 'estabelecimentos', estabId, 'pedidos'), orderBy('createdAt', 'desc')));\r\n      console.log('­ƒôª Total de pedidos encontrados:', snap.docs.length);\r\n      const comAvaliacao = snap.docs\r\n        .map(d => ({ id: d.id, ...d.data() }))\r\n        .filter(p => p.avaliacao && (p.avaliacao.estrelas || p.avaliacao.rating));\r\n      console.log('Ô¡É Pedidos com avalia├º├úo:', comAvaliacao.length);\r\n      // Normaliza: garante que sempre usa `estrelas`\r\n      const normalizados = comAvaliacao.map(p => ({\r\n        ...p,\r\n        avaliacao: { ...p.avaliacao, estrelas: p.avaliacao.estrelas || p.avaliacao.rating }\r\n      }));\r\n      setPedidos(normalizados);\r\n      setLoading(false);\r\n    };\r\n    load();\r\n  }, [estabId]);\r\n\r\n  const responder = async (pedidoId) => {\r\n    const texto = respostas[pedidoId];\r\n    if (!texto?.trim()) return toast.warn('Escreva uma resposta!');\r\n    try {\r\n      await updateDoc(doc(db, 'estabelecimentos', estabId, 'pedidos', pedidoId), {\r\n        'avaliacao.resposta': texto.trim(),\r\n        'avaliacao.respondidoEm': new Date()\r\n      });\r\n      setPedidos(prev => prev.map(p => p.id === pedidoId ? { ...p, avaliacao: { ...p.avaliacao, resposta: texto.trim() } } : p));\r\n      setRespostas(prev => ({ ...prev, [pedidoId]: '' }));\r\n      toast.success('Ô£à Resposta enviada!');\r\n    } catch (e) {\r\n      toast.error('Erro ao responder');\r\n    }\r\n  };\r\n\r\n  const filtered = pedidos.filter(p => {\r\n    if (filtro === 'sem_resposta') return !p.avaliacao?.resposta;\r\n    if (filtro === 'respondidos') return !!p.avaliacao?.resposta;\r\n    return true;\r\n  });\r\n\r\n  const mediaEstrelas = pedidos.length > 0 ? (pedidos.reduce((acc, p) => acc + p.avaliacao.estrelas, 0) / pedidos.length).toFixed(1) : '0';\r\n\r\n  const renderStars = (n) => Array.from({ length: 5 }, (_, i) => (\r\n    <span key={i}>{i < n ? <IoStar className=\"text-amber-400\" /> : <IoStarOutline className=\"text-gray-300\" />}</span>\r\n  ));\r\n\r\n  if (loading) return (\r\n    <div className=\"min-h-screen bg-gray-50 flex items-center justify-center\">\r\n      <div className=\"animate-spin rounded-full h-10 w-10 border-2 border-amber-500 border-t-transparent\" />\r\n    </div>\r\n  );\r\n\r\n  return (\r\n    <div className=\"min-h-screen bg-[#F8FAFC] p-4 sm:p-6 font-sans pb-20\">\r\n      <div className=\"max-w-3xl mx-auto\">\r\n\r\n        <div className=\"flex items-center gap-3 mb-6\">\r\n          <BackButton to=\"/dashboard\" />\r\n          <div>\r\n            <h1 className=\"text-xl font-black text-gray-900 flex items-center gap-2\"><IoChatbubbleEllipsesOutline className=\"text-amber-500\" /> Avalia├º├Áes</h1>\r\n            <p className=\"text-xs text-gray-400 font-medium\">Veja e responda as avalia├º├Áes dos clientes</p>\r\n          </div>\r\n        </div>\r\n\r\n        {/* Stats */}\r\n        <div className=\"grid grid-cols-3 gap-3 mb-6\">\r\n          <div className=\"bg-white rounded-2xl p-4 border border-gray-100 shadow-sm text-center\">\r\n            <p className=\"text-3xl font-black text-amber-500\">{mediaEstrelas}</p>\r\n            <p className=\"text-[10px] text-gray-400 font-bold uppercase\">M├®dia</p>\r\n          </div>\r\n          <div className=\"bg-white rounded-2xl p-4 border border-gray-100 shadow-sm text-center\">\r\n            <p className=\"text-3xl font-black text-gray-900\">{pedidos.length}</p>\r\n            <p className=\"text-[10px] text-gray-400 font-bold uppercase\">Total</p>\r\n          </div>\r\n          <div className=\"bg-white rounded-2xl p-4 border border-gray-100 shadow-sm text-center\">\r\n            <p className=\"text-3xl font-black text-green-600\">{pedidos.filter(p => p.avaliacao?.resposta).length}</p>\r\n            <p className=\"text-[10px] text-gray-400 font-bold uppercase\">Respondidas</p>\r\n          </div>\r\n        </div>\r\n\r\n        {/* Filtro */}\r\n        <div className=\"flex gap-2 mb-5\">\r\n          {[['todos', 'Todas'], ['sem_resposta', 'Sem resposta'], ['respondidos', 'Respondidas']].map(([k, label]) => (\r\n            <button key={k} onClick={() => setFiltro(k)}\r\n              className={`px-4 py-2 rounded-xl text-xs font-black transition-all ${filtro === k ? 'bg-amber-500 text-white shadow-lg shadow-amber-200' : 'bg-white text-gray-600 border border-gray-200 hover:bg-gray-50'}`}>\r\n              {label}\r\n            </button>\r\n          ))}\r\n        </div>\r\n\r\n        {/* Lista */}\r\n        {filtered.length === 0 ? (\r\n          <div className=\"bg-white rounded-2xl border-2 border-dashed border-gray-200 p-12 text-center\">\r\n            <IoStarOutline className=\"text-5xl text-gray-300 mx-auto mb-3\" />\r\n            <p className=\"text-gray-500 font-bold\">Nenhuma avalia├º├úo encontrada</p>\r\n          </div>\r\n        ) : (\r\n          <div className=\"space-y-3\">\r\n            {filtered.map(p => (\r\n              <div key={p.id} className=\"bg-white rounded-2xl border border-gray-100 shadow-sm p-5\">\r\n                <div className=\"flex items-start justify-between mb-3\">\r\n                  <div>\r\n                    <p className=\"text-sm font-bold text-gray-800\">{p.cliente?.nome || p.nomeCliente || 'Cliente'}</p>\r\n                    <p className=\"text-[10px] text-gray-400\">\r\n                      Pedido #{p.id.slice(-6).toUpperCase()} ÔÇó {p.createdAt?.toDate?.() ? new Intl.DateTimeFormat('pt-BR').format(p.createdAt.toDate()) : ''}\r\n                    </p>\r\n                  </div>\r\n                  <div className=\"flex items-center gap-0.5\">{renderStars(p.avaliacao.estrelas)}</div>\r\n                </div>\r\n\r\n                {p.avaliacao.comentario && (\r\n                  <p className=\"text-sm text-gray-700 bg-gray-50 rounded-xl p-3 mb-3 italic\">\"{p.avaliacao.comentario}\"</p>\r\n                )}\r\n\r\n                {p.avaliacao.resposta ? (\r\n                  <div className=\"bg-green-50 border border-green-200 rounded-xl p-3\">\r\n                    <p className=\"text-[10px] font-bold text-green-600 mb-1 flex items-center gap-1\"><IoCheckmarkCircle /> Sua resposta:</p>\r\n                    <p className=\"text-sm text-green-800\">{p.avaliacao.resposta}</p>\r\n                  </div>\r\n                ) : (\r\n                  <div className=\"flex gap-2\">\r\n                    <input value={respostas[p.id] || ''} onChange={e => setRespostas(prev => ({ ...prev, [p.id]: e.target.value }))}\r\n                      className=\"flex-1 p-2.5 bg-gray-50 border border-gray-200 rounded-xl text-sm outline-none focus:ring-2 focus:ring-amber-200\"\r\n                      placeholder=\"Escreva sua resposta...\"\r\n                      onKeyDown={e => e.key === 'Enter' && responder(p.id)}\r\n                    />\r\n                    <button onClick={() => responder(p.id)} className=\"px-4 py-2.5 bg-amber-500 hover:bg-amber-600 text-white rounded-xl transition-all shadow-lg shadow-amber-200\">\r\n                      <IoSendOutline />\r\n                    </button>\r\n                  </div>\r\n                )}\r\n              </div>\r\n            ))}\r\n          </div>\r\n        )}\r\n      </div>\r\n    </div>\r\n  );\r\n}\r\n\r\nexport default withEstablishmentAuth(ResponderAvaliacoes);\r\n","usedDeprecatedRules":[{"ruleId":"no-extra-semi","replacedBy":["@stylistic/no-extra-semi"],"info":{"message":"Formatting rules are being moved out of ESLint core.","url":"https://eslint.org/blog/2023/10/deprecating-formatting-rules/","deprecatedSince":"8.53.0","availableUntil":"11.0.0","replacedBy":[{"message":"ESLint Stylistic now maintains deprecated stylistic core rules.","url":"https://eslint.style/guide/migration","plugin":{"name":"@stylistic/eslint-plugin","url":"https://eslint.style"},"rule":{"name":"no-extra-semi","url":"https://eslint.style/rules/no-extra-semi"}}]}},{"ruleId":"no-mixed-spaces-and-tabs","replacedBy":["@stylistic/no-mixed-spaces-and-tabs"],"info":{"message":"Formatting rules are being moved out of ESLint core.","url":"https://eslint.org/blog/2023/10/deprecating-formatting-rules/","deprecatedSince":"8.53.0","available