ion-all hover:shadow-md\">\r\n            <h3 className=\"text-base font-bold text-gray-900 mb-4 flex items-center gap-2\"><IoCalendarOutline className=\"text-emerald-500\"/> ├Ültimos Resgates</h3>\r\n            \r\n            {campanhas.length === 0 ? (\r\n              <div className=\"text-center py-8 bg-gray-50 rounded-xl border border-dashed border-gray-200\">\r\n                <p className=\"text-sm font-medium text-gray-500\">Nenhum envio registrado ainda.</p>\r\n                <p className=\"text-xs text-gray-400 mt-1\">Os resgates aparecer├úo aqui quando o rob├┤ rodar.</p>\r\n              </div>\r\n            ) : (\r\n              <div className=\"space-y-3 max-h-[250px] overflow-y-auto pr-2 custom-scrollbar\">\r\n                {campanhas.map(c => (\r\n                  <div key={c.id} className=\"flex flex-col p-3.5 bg-gray-50 rounded-xl border border-gray-100 hover:bg-gray-100/50 transition-colors\">\r\n                    <div className=\"flex justify-between items-start\">\r\n                      <span className=\"text-sm font-bold text-gray-800\">{c.clienteNome || 'Cliente An├┤nimo'}</span>\r\n                      <span className=\"text-[10px] font-bold text-emerald-700 bg-emerald-100 px-2 py-0.5 rounded-md uppercase tracking-wider\">{c.status}</span>\r\n                    </div>\r\n                    <p className=\"text-xs text-gray-500 mt-1.5 font-medium\">Resgatado ap├│s {c.diasInativo} dias inativo</p>\r\n                  </div>\r\n                ))}\r\n              </div>\r\n            )}\r\n          </div>\r\n\r\n        </div>\r\n      </div>\r\n      \r\n    </div>\r\n  );\r\n}\r\n\r\nexport default withEstablishmentAuth(MarketingConfig);\r\n","usedDeprecatedRules":[{"ruleId":"no-extra-semi","replacedBy":["@stylistic/no-extra-semi"],"info":{"message":"Formatting rules are being moved out of ESLint core.","url":"https://eslint.org/blog/2023/10/deprecating-formatting-rules/","deprecatedSince":"8.53.0","availableUntil":"11.0.0","