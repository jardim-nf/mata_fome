{
  "name": "ideafood",
  "version": "0.0.1",
  "scripts": {
    "dev": "concurrently \"vite\" \"node local-bridge.js\"",
    "bridge": "node local-bridge.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "prepare": "husky",
    "deploy:front": "npm run build && firebase deploy --only hosting",
