    "deploy:fiscal": "firebase deploy --only functions:emitirNfceBackend,functions:cancelarNfceBackend,functions:consultarStatusNfce",
    "deploy:wpp": "firebase deploy --only functions:handleWebhookPost",
    "deploy:admin": "firebase deploy --only functions:criarEstabelecimento,functions:atualizarEstabelecimento",
    "howard": "node scripts/howard_qa.js"
  },
