{
  "name": "ideafood-local-server",
  "version": "1.0.0",
  "description": "Local Event Bus for Offline Synchronization",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "build": "pkg . --targets node18-win-x64 --output ServidorIdeaFood.exe"
  },
  "pkg": {
    "scripts": ["server.js"],
    "targets": ["node18-win-x64"],
    "outputPath": "dist"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  }
}
