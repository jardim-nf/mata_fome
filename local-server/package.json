{
  "name": "ideafood-local-server",
  "version": "2.0.0",
  "description": "Local Event Bus & Agent Squad Execution Server",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "pkg . --targets node18-win-x64 --output ServidorIdeaFood.exe"
  },
  "pkg": {
    "scripts": [
      "server.js"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "socket.io": "^4.7.2"
  }
}
